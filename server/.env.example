# Google AI Studio에서 발급한 Gemini API 키 (필수)
GOOGLE_API_KEY=

# 비워두면 프로젝트 루트의 vector_db 폴더를 자동으로 사용합니다.
VECTOR_DB_PATH=

# 아래 값들은 vector_db.zip을 만들 때 쓴 설정과 반드시 일치해야 합니다.
EMBEDDING_MODEL_NAME=jhgan/ko-sroberta-multitask
CHROMA_COLLECTION_NAME=langchain

# 기초스터디프로젝트_v2.ipynb에서 검증한 모델명 (필요 시 교체)
GEMINI_MODEL_NAME=gemini-3.5-flash
